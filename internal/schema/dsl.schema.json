{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slsbench.example.com/schema/dsl.schema.json",
  "title": "Slsbench DSL",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the benchmark or scenario"
    },
    "description": {
      "type": "string",
      "description": "Human readable description"
    },
    "version": {
      "type": "string",
      "description": "DSL version identifier"
    }
  },
  "required": ["name"],
  "additionalProperties": true
}


